{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Autolycus Desktop",
  "version": "0.3.0",
  "identifier": "com.autolycus.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Autolycus",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "© 2026 Autolycus Team",
    "category": "DeveloperTool",
    "shortDescription": "AI Assistant Desktop App",
    "longDescription": "Autolycus Desktop — native desktop AI assistant powered by Hermes Agent",
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.0-37", "libssl3", "libgtk-3-0", "librsvg2-2"]
      }
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {}
}
